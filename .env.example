# Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to git - it contains secrets!

# ===== SUPABASE =====
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===== FLUTTERWAVE =====
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_xxxxxxxxxxxxxxxxxxxxx

# ===== CJ DROPSHIPPING =====
VITE_CJ_API_KEY=your-cj-api-key-here
VITE_CJ_API_URL=https://developers.cjdropshipping.com/api2.0/v1

# ===== BACKEND/API =====
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# ===== APP SETTINGS =====
VITE_APP_NAME=Wimp-Drop
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# ===== FEATURE FLAGS =====
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_WISHLIST=true
VITE_ENABLE_GUEST_CHECKOUT=false
VITE_ENABLE_PROMO_CODES=true

# ===== PAYMENT SETTINGS =====
VITE_DEFAULT_CURRENCY=NGN
VITE_TAX_RATE=0.10
VITE_SHIPPING_STANDARD_COST=9.99
VITE_SHIPPING_EXPRESS_COST=19.99

# ===== ANALYTICS (Optional) =====
# VITE_GOOGLE_ANALYTICS_ID=UA-XXXXX-X
# VITE_SENTRY_DSN=https://...

# ===== DEBUG =====
VITE_DEBUG_MODE=false
VITE_LOG_API_CALLS=false
